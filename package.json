{
  "name": "anchor",
  "displayName": "Anchor",
  "description": "Harpoon-like file navigation for VS Code. Anchor files and jump to them instantly.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "anchor.addFile",
        "title": "Anchor: Add Current File"
      },
      {
        "command": "anchor.removeFile",
        "title": "Anchor: Remove Current File"
      },
      {
        "command": "anchor.toggleList",
        "title": "Anchor: Toggle List"
      },
      {
        "command": "anchor.goToFile1",
        "title": "Anchor: Go to File 1"
      },
      {
        "command": "anchor.goToFile2",
        "title": "Anchor: Go to File 2"
      },
      {
        "command": "anchor.goToFile3",
        "title": "Anchor: Go to File 3"
      },
      {
        "command": "anchor.goToFile4",
        "title": "Anchor: Go to File 4"
      },
      {
        "command": "anchor.goToFile5",
        "title": "Anchor: Go to File 5"
      },
      {
        "command": "anchor.goToFile6",
        "title": "Anchor: Go to File 6"
      },
      {
        "command": "anchor.goToFile7",
        "title": "Anchor: Go to File 7"
      },
      {
        "command": "anchor.goToFile8",
        "title": "Anchor: Go to File 8"
      },
      {
        "command": "anchor.goToFile9",
        "title": "Anchor: Go to File 9"
      }
    ],
    "keybindings": [
      {
        "command": "anchor.addFile",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "anchor.removeFile",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "anchor.toggleList",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      },
      {
        "command": "anchor.goToFile1",
        "key": "ctrl+1",
        "mac": "cmd+1"
      },
      {
        "command": "anchor.goToFile2",
        "key": "ctrl+2",
        "mac": "cmd+2"
      },
      {
        "command": "anchor.goToFile3",
        "key": "ctrl+3",
        "mac": "cmd+3"
      },
      {
        "command": "anchor.goToFile4",
        "key": "ctrl+4",
        "mac": "cmd+4"
      },
      {
        "command": "anchor.goToFile5",
        "key": "ctrl+5",
        "mac": "cmd+5"
      },
      {
        "command": "anchor.goToFile6",
        "key": "ctrl+6",
        "mac": "cmd+6"
      },
      {
        "command": "anchor.goToFile7",
        "key": "ctrl+7",
        "mac": "cmd+7"
      },
      {
        "command": "anchor.goToFile8",
        "key": "ctrl+8",
        "mac": "cmd+8"
      },
      {
        "command": "anchor.goToFile9",
        "key": "ctrl+9",
        "mac": "cmd+9"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
